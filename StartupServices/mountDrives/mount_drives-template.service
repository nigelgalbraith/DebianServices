[Unit]
Description=Mount media drive(s) on startup
Wants=network-online.target
After=network-online.target
ConditionPathExists=/usr/local/bin/mount_drives.py

# Ensure mount points exist before running
RequiresMountsFor=/mnt
ConditionPathIsDirectory=/mnt

[Service]
Type=oneshot
ExecStart=/usr/bin/python3 /usr/local/bin/mount_drives.py
StandardOutput=append:/var/log/mount_drives.log
StandardError=append:/var/log/mount_drives.log
RemainAfterExit=true
User=root
Group=root
Environment="PYTHONUNBUFFERED=1" "LANG=C.UTF-8" "LC_ALL=C.UTF-8"

[Install]
WantedBy=multi-user.target